{
  "name": "@picro/picro",
  "version": "0.0.1",
  "description": "picro agnent",
  "private": false,
  "type": "module",
  "bin": {
    "picro": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:tui && tsc && chmod +x dist/cli.js",
    "build:tui": "tsup src/tui/ink/index.ts --format esm --platform node --target node20 --out-dir dist/tui && echo '{\"type\":\"module\"}' > dist/tui/package.json",
    "dev": "VERBOSE=1 picro",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "picro",
    "ai",
    "agent",
    "llm",
    "tui"
  ],
  "author": "picro",
  "license": "APACHE",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/clipboardy": "^1.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.15",
    "@typescript/native-preview": "^7.0.0-dev.20260512.1",
    "@vitest/coverage-v8": "^4.1.5",
    "highlight.js": "^11.11.1",
    "jsdom": "^29.1.1",
    "react-test-renderer": "^19.2.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "arabic-reshaper": "^1.1.0",
    "ink": "^7.0.3",
    "openai": "^6.35.0",
    "partial-json": "^0.1.7",
    "react": "^19.2.6",
    "strip-ansi": "^7.2.0"
  }
}
