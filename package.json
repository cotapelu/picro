{
  "name": "@picro/monorepo",
  "version": "0.0.1",
  "description": "Monorepo for AI agent packages",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:llm && npm run build:tui && npm run build:memory && npm run build:agent",
    "build:llm": "cd packages/llm && npm run build",
    "build:agent": "cd packages/agent && npm run build",
    "build:memory": "cd packages/memory && npm run build",
    "build:tui": "cd packages/tui && npm run build",
    "build:example": "tsc -p src/tsconfig.json",
    "start:example": "node src/dist/main.js",
    "clean": "cd packages/llm && npm run clean && cd ../agent && npm run clean && cd ../memory && npm run clean && cd ../tui && rm -rf dist",
    "dev": "npm run dev:llm",
    "dev:llm": "cd packages/llm && npm run dev",
    "dev:agent": "cd packages/agent && npm run dev",
    "dev:memory": "cd packages/memory && npm run dev",
    "dev:tui": "cd packages/tui && npm run dev",
    "test": "npm run test:llm && npm run test:agent && npm run test:memory",
    "test:llm": "cd packages/llm && npm run test",
    "test:agent": "cd packages/agent && npm run test",
    "test:memory": "cd packages/memory && npm run test",
    "test:tui": "cd packages/tui && npm run test"
  },
  "keywords": [
    "monorepo",
    "ai",
    "agent",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
