{
  "name": "@picro/picro",
  "version": "0.0.1",
  "description": "picro agnent",
  "type": "module",
  "private": false,
  "bin": {
    "picro": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && npm run build:tui && cp src/tui-bootstrap.js dist/ && chmod +x dist/cli.js",
    "build:tui": "node scripts/build-tui.js",
    "dev": "VERBOSE=1 picro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage:each": "bash scripts/test-coverage-each.sh",
    "test:coverage:single": "vitest run --coverage --reporter=json"
  },
  "keywords": [
    "picro",
    "ai",
    "agent",
    "llm",
    "tui"
  ],
  "author": "picro",
  "license": "APACHE",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.2",
    "@types/clipboardy": "^1.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260512.1",
    "@vitest/coverage-v8": "^4.1.5",
    "clipboardy": "^5.3.1",
    "glob": "^13.0.6",
    "highlight.js": "^11.11.1",
    "ink-testing-library": "^4.0.0",
    "jsdom": "^29.1.1",
    "react-dom": "^19.2.6",
    "react-test-renderer": "^19.2.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.1",
    "@types/proper-lockfile": "^4.1.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "arabic-reshaper": "^1.1.0",
    "ink": "^7.0.3",
    "openai": "^6.35.0",
    "partial-json": "^0.1.7",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.6",
    "strip-ansi": "^7.2.0"
  }
