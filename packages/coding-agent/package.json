{
  "name": "@picro/coding-agent",
  "version": "0.0.1",
  "description": "Interactive Coding Agent with TUI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "coding-agent": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": ["agent", "coding", "ai", "tui", "interactive"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@picro/agent": "file:../agent",
    "@picro/llm": "file:../llm",
    "@picro/tui": "file:../tui",
    "@picro/memory": "file:../memory"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^1.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}