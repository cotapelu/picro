{
  "name": "@picro/llm",
  "version": "0.0.1",
  "description": "OpenAI-compatible LLM library with 800+ models across 23 providers",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./openai-compatible": {
      "import": "./dist/src/providers/openai-compatible.js",
      "types": "./dist/src/providers/openai-compatible.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "generate-models": "npx tsx scripts/generate-models.ts",
    "build": "npm run generate-models && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "nvidia",
    "nim",
    "groq",
    "openrouter",
    "unified",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "openai": "^6.26.0",
    "partial-json": "^0.1.7"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^4.1.4",
    "happy-dom": "^20.9.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
