 File: src/components/truncated-text.ts                                                                                                                                                 
 From: pi-tui-legacy/components/truncated-text.ts                                                                                                                                       
 Purpose: Text component that truncates with ellipsis at exact width.                                                                                                                   
 API:                                                                                                                                                                                   
                                                                                                                                                                                        
 ```typescript                                                                                                                                                                          
   class TruncatedText implements UIElement {                                                                                                                                           
     constructor(private text: string, paddingX = 0, paddingY = 0);                                                                                                                     
     setText(text: string): void;                                                                                                                                                       
     render(width: number): string[];                                                                                                                                                   
   }                                                                                                                                                                                    
 ```                                                                                                                                                                                    
                                                                                                                                                                                        
 Implementation:                                                                                                                                                                        
 - Use visibleWidth(), truncateToWidth() from utils                                                                                                                                     
