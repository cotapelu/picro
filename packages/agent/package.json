{
  "name": "@picro/agent",
  "version": "0.0.1",
  "description": "Core agent logic for tool-based AI agents",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "agent",
    "ai",
    "tool-calling",
    "automation"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@picro/llm": "*"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}