{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist/tui",
    "rootDir": "src/tui",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": ["src/tui/**/*.ts", "src/tui/**/*.tsx"],
  "exclude": ["node_modules"]
}
