{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "node",
    "outDir": "./dist/tui",
    "rootDir": "./src/tui",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src/tui/**/*"],
  "exclude": ["node_modules", "dist"]
}
