{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@picro/agent": ["src/agent"],
      "@picro/tui": ["src/tui"],
      "@picro/llm": ["src/llm"],
      "@picro/memory": ["src/memory"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
