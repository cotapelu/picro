{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/llm",
    "rootDir": "./src/llm",
    "skipLibCheck": true,
    "downlevelIteration": true,
    "lib": ["ES2022"],
    "target": "ES2022"
  },
  "include": ["src/llm/**/*.ts"],
  "exclude": ["node_modules", "src/llm/**/*.test.ts", "src/llm/**/*.extra.test.ts", "src/llm/scripts"]
}
